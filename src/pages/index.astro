---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import DnsForm from '../components/DnsForm.astro';
---

<BaseLayout title="Cloudflare DNS Zone File Generator">
	<h1>Cloudflare BIND Zone Generator</h1>
	<p class="description">Generate file konfigurasi DNS standar untuk langsung di-import ke Cloudflare secara client-side aman.</p>
	
	<!-- Memanggil komponen Form -->
	<DnsForm />

	<footer>
		100% Client-Side. Data IP dan Domain Anda tidak dikirim ke server mana pun.
	</footer>
</BaseLayout>

<style>
	h1 { font-size: 1.75rem; margin-top: 0; color: var(--primary); text-align: center; }
	.description { text-align: center; color: #6b7280; margin-bottom: 2rem; font-size: 0.95rem; }
	footer { margin-top: 2rem; text-align: center; font-size: 0.8rem; color: #9ca3af; }
</style>
